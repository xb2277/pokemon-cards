<!-- 卡牌图鉴 -->
<view class="page-container">

  <view class="search-bar" style="margin-bottom:12rpx;">
    <view class="icon"></view>
    <input placeholder="搜索卡名 / 编号 / 系列" bindinput="onSearchInput" value="{{search}}"/>
  </view>

  <!-- Filter chips -->
  <scroll-view class="filter-chips" scroll-x>
    <view class="chip {{activeSet === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="set" data-v="all">全部系列</view>
    <view class="chip {{activeSet === item ? 'active' : ''}}" wx:for="{{sets}}" wx:key="*this" bindtap="setFilter" data-type="set" data-v="{{item}}">{{item}}</view>
  </scroll-view>
  <scroll-view class="filter-chips" scroll-x style="padding-top:0;">
    <view class="chip {{activeRarity === '' ? 'active' : ''}}" bindtap="setFilter" data-type="rarity" data-v="">全部</view>
    <view class="chip {{activeRarity === item ? 'active' : ''}}" wx:for="{{rarityFilter}}" wx:key="*this" bindtap="setFilter" data-type="rarity" data-v="{{item}}">{{item}}</view>
  </scroll-view>

  <!-- Actions -->
  <view style="display:flex;gap:12rpx;margin:12rpx 0 20rpx;">
    <button class="btn btn-outline btn-sm" bindtap="showBulkSheet">批量导入</button>
    <button class="btn btn-primary btn-sm" bindtap="showAddSheet">新增卡种</button>
  </view>

  <!-- Grid -->
  <view class="card-grid" wx:if="{{items.length > 0}}">
    <view class="card-cell" wx:for="{{items}}" wx:key="id" bindtap="editItem" data-id="{{item.id}}">
      <view class="cover">
        <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="aspectFill"/>
        <view wx:else class="placeholder">🃏</view>
      </view>
      <view class="info">
        <view class="title">{{item.name}}</view>
        <view class="meta">
          <text class="set">{{item.card_number || item.set_name || '--'}}</text>
          <text wx:if="{{item.rarity}}" class="badge badge-{{item.rarity}}">{{item.rarity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{items.length === 0 && !loading}}">
    <view class="icon">📋</view>
    <view class="msg">{{search ? '没有找到匹配的卡种' : '图鉴还是空的'}}</view>
    <view class="sub" wx:if="{{!search}}">点击「新增卡种」或「批量导入」添加</view>
  </view>

  <view class="pager" wx:if="{{totalPages > 1}}">
    <text>共 {{total}} 条 / {{page}}/{{totalPages}} 页</text>
    <button class="btn btn-outline btn-sm" wx:if="{{page > 1}}" bindtap="goPage" data-p="{{page - 1}}">‹</button>
    <button class="btn btn-outline btn-sm" wx:if="{{page < totalPages}}" bindtap="goPage" data-p="{{page + 1}}">›</button>
  </view>

</view>

<!-- ====== Add/Edit Sheet ====== -->
<view class="modal-mask" wx:if="{{showSheet}}" bindtap="hideSheet">
  <view class="modal-sheet" catchtap="noop">
    <view class="ms-header">
      <text class="title">{{editing ? '编辑卡种' : '新增卡种'}}</text>
      <view class="close" bindtap="hideSheet">✕</view>
    </view>
    <view class="ms-body">
      <view class="form-field">
        <view class="label">卡牌图片</view>
        <view class="img-upload" bindtap="pickImage">
          <image wx:if="{{form.image_url}}" src="{{form.image_url}}" mode="aspectFit"/>
          <view wx:else class="hint">点击拍照或选择图片</view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">卡名 *</view><input placeholder="皮卡丘 VMAX" value="{{form.name}}" data-k="name" bindinput="onField"/></view>
        <view class="form-field"><view class="label">英文名</view><input placeholder="Pikachu VMAX" value="{{form.name_en}}" data-k="name_en" bindinput="onField"/></view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">系列名称</view><input placeholder="朱紫 sV" value="{{form.set_name}}" data-k="set_name" bindinput="onField"/></view>
        <view class="form-field"><view class="label">系列代码</view><input placeholder="sv1a" value="{{form.set_code}}" data-k="set_code" bindinput="onField"/></view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">编号</view><input placeholder="060/072" value="{{form.card_number}}" data-k="card_number" bindinput="onField"/></view>
        <view class="form-field">
          <view class="label">稀有度</view>
          <picker range="{{rarityPickList}}" value="{{form.rarityIdx}}" bindchange="onRarityPick">
            <view>{{rarityPickList[form.rarityIdx]}}</view>
          </picker>
        </view>
      </view>
      <view class="form-field">
        <view class="label">备注</view>
        <textarea placeholder="发行说明等..." value="{{form.description}}" data-k="description" bindinput="onField"/>
      </view>
    </view>
    <view class="ms-footer">
      <button wx:if="{{editing}}" class="btn btn-danger" style="margin-right:auto;" bindtap="deleteCurrent">删除</button>
      <button class="btn btn-outline" style="flex:1;" bindtap="hideSheet">取消</button>
      <button class="btn btn-primary" style="flex:1;" bindtap="saveItem" loading="{{saving}}">{{editing ? '更新' : '保存'}}</button>
    </view>
  </view>
</view>

<!-- ====== Bulk Import Sheet ====== -->
<view class="modal-mask" wx:if="{{showBulk}}" bindtap="hideBulk">
  <view class="modal-sheet" catchtap="noop">
    <view class="ms-header">
      <text class="title">批量导入</text>
      <view class="close" bindtap="hideBulk">✕</view>
    </view>
    <view class="ms-body">
      <view style="border:2rpx dashed var(--border);border-radius:16rpx;padding:60rpx 20rpx;text-align:center;background:var(--card);" bindtap="pickJsonFile">
        <text style="font-weight:700;">点击选择 JSON 文件</text>
        <view style="font-size:24rpx;color:var(--text3);margin-top:12rpx;">格式: [{"name":"皮卡丘","set_name":"sV",...}]</view>
      </view>
      <view wx:if="{{bulkItems.length > 0}}" style="margin-top:24rpx;">
        <view style="display:flex;justify-content:space-between;margin-bottom:16rpx;">
          <text style="font-weight:700;">{{bulkItems.length}} 条记录</text>
          <button class="btn btn-outline btn-sm" bindtap="clearBulk">清空</button>
        </view>
        <view class="dropdown" style="max-height:280rpx;">
          <view class="dropdown-item" wx:for="{{bulkItems.slice(0, 50)}}" wx:key="index">
            <view>
              <view class="dd-name">{{item.name}}</view>
              <view class="dd-meta">{{item.set_name}} · {{item.card_number}} · {{item.rarity}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="ms-footer">
      <button class="btn btn-outline" style="flex:1;" bindtap="hideBulk">取消</button>
      <button class="btn btn-primary" style="flex:1;" bindtap="doImport" loading="{{importing}}" disabled="{{bulkItems.length === 0}}">导入</button>
    </view>
  </view>
</view>
