<!-- 价格行情 -->
<view class="page-container">

  <!-- Hero: Card selector -->
  <view class="price-hero">
    <view class="hero-top">
      <view class="hero-img">
        <image wx:if="{{sel.image}}" src="{{sel.image}}" mode="aspectFit" style="width:100%;height:100%;"/>
        <view wx:else style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:64rpx;color:var(--text3);">?</view>
      </view>
      <view class="hero-info">
        <view class="name">{{sel.name || '选择卡牌查看行情'}}</view>
        <view class="sub" wx:if="{{sel.sub}}">{{sel.sub}}</view>
        <view class="hero-actions">
          <button class="btn btn-primary btn-sm" bindtap="doRefresh" loading="{{refreshing}}">刷新价格</button>
          <button class="btn btn-outline btn-sm" bindtap="toggleManual">手动录入</button>
        </view>
      </view>
    </view>

    <!-- Catalog Picker Trigger -->
    <view class="form-field" style="margin:20rpx 0 0;">
      <view class="picker-trigger" bindtap="openCatalogPicker">
        <text wx:if="{{sel.name}}">{{sel.name}}</text>
        <text wx:else style="color:var(--text3);">{{cardId ? '重新选择卡牌' : '点击搜索图鉴选择卡牌'}}</text>
        <text class="picker-arrow">🔍</text>
      </view>
    </view>
  </view>

  <!-- Stats -->
  <view class="stat-row" wx:if="{{cardId}}">
    <view class="stat-box"><view class="val" style="color:var(--gold);">{{latest.avg || '--'}}</view><view class="lbl">均价</view></view>
    <view class="stat-box"><view class="val" style="color:var(--green);">{{latest.max || '--'}}</view><view class="lbl">最高</view></view>
    <view class="stat-box"><view class="val" style="color:var(--amber);">{{latest.min || '--'}}</view><view class="lbl">最低</view></view>
    <view class="stat-box"><view class="val">{{latest.count || 0}}</view><view class="lbl">记录数</view></view>
  </view>

  <!-- Not in collection notice -->
  <view class="chart-card" wx:if="{{sel.name && notInCollection}}">
    <view style="text-align:center;padding:20rpx 0;">
      <view style="font-size:64rpx;margin-bottom:16rpx;">📋</view>
      <view style="font-weight:600;margin-bottom:8rpx;">你还未添加此卡牌到收藏</view>
      <view style="color:var(--text3);font-size:26rpx;">请先在"我的收藏"中添加此卡牌，即可查看价格行情</view>
    </view>
  </view>

  <!-- Chart -->
  <view class="chart-card" wx:if="{{chartReady}}">
    <h3>价格走势</h3>
    <ec-canvas id="priceChart" canvas-id="priceChart" ec="{{priceEc}}"></ec-canvas>
  </view>
  <view wx:if="{{cardId && !chartReady && noHistory}}" style="text-align:center;padding:40rpx;color:var(--text3);">
    暂无价格记录
  </view>

  <!-- Manual Input -->
  <view class="chart-card" wx:if="{{showManual && cardId}}">
    <h3>手动录入</h3>
    <view style="display:flex;gap:12rpx;align-items:center;">
      <input style="flex:1;height:72rpx;background:var(--card);border-radius:12rpx;padding:0 16rpx;" type="digit" placeholder="价格 ¥" value="{{mPrice}}" bindinput="onMPrice"/>
      <input style="width:180rpx;height:72rpx;background:var(--card);border-radius:12rpx;padding:0 16rpx;" placeholder="来源" value="{{mPlatform}}" bindinput="onMPlatform"/>
      <button class="btn btn-success btn-sm" bindtap="submitManual">录入</button>
    </view>
  </view>

  <!-- Empty -->
  <view class="empty" wx:if="{{!cardId}}">
    <view class="icon">📈</view>
    <view class="msg">选择一张卡牌查看价格</view>
    <view class="sub">点击上方搜索框从图鉴中选择</view>
  </view>

</view>

<!-- ====== Catalog Picker Modal ====== -->
<view class="modal-mask" wx:if="{{pickerVisible}}" bindtap="closeCatalogPicker">
  <view class="modal-sheet" catchtap="noop">
    <view class="ms-header">
      <text class="title">从图鉴选择卡牌</text>
      <view class="close" bindtap="closeCatalogPicker">✕</view>
    </view>
    <view class="ms-body">
      <view class="search-bar" style="margin-bottom:20rpx;">
        <view class="icon"></view>
        <input
          placeholder="搜索卡名 / 编号 / 系列..."
          bindinput="onCatalogSearch"
          value="{{catalogSearch}}"
          focus="{{pickerVisible}}"
        />
      </view>
      <view class="dropdown" wx:if="{{catalogResults.length > 0}}" style="max-height:none;border:none;">
        <view class="dropdown-item" wx:for="{{catalogResults}}" wx:key="id" bindtap="selectCatalogCard" data-id="{{item.id}}">
          <image wx:if="{{item.image_url}}" src="{{item.image_url}}" class="thumb" mode="aspectFill"/>
          <view wx:else class="thumb" style="display:flex;align-items:center;justify-content:center;background:var(--card);font-size:28rpx;">🃏</view>
          <view>
            <view class="dd-name">{{item.name}}<text wx:if="{{item.name_en}}" style="color:var(--text3);font-weight:400;"> / {{item.name_en}}</text></view>
            <view class="dd-meta">{{item.set_name}} · {{item.card_number}} · {{item.rarity}}</view>
          </view>
        </view>
      </view>
      <view wx:elif="{{catalogSearch && !catalogLoading}}" style="text-align:center;padding:40rpx;color:var(--text3);">
        未找到匹配的卡牌
      </view>
      <view wx:if="{{!catalogSearch && catalogResults.length === 0}}" style="text-align:center;padding:40rpx;color:var(--text3);">
        请输入关键词搜索图鉴
      </view>
    </view>
  </view>
</view>
