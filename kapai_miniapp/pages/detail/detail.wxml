<!-- 卡牌详情 -->
<view class="page-container" wx:if="{{card}}">

  <!-- Image + Name -->
  <view class="detail-header">
    <image wx:if="{{card.image_path}}" src="{{card.image_path}}" mode="aspectFit"/>
    <view wx:else class="placeholder">♢</view>
    <view class="detail-name">{{card.name}}</view>
    <view class="detail-ename" wx:if="{{card.name_en}}">{{card.name_en}}</view>
  </view>

  <!-- Info Grid -->
  <view class="info-grid">
    <view class="info-cell"><view class="lbl">系列</view><view class="val">{{card.set_name || '--'}}</view></view>
    <view class="info-cell"><view class="lbl">编号</view><view class="val">{{card.card_number || '--'}}</view></view>
    <view class="info-cell"><view class="lbl">稀有度</view><view class="val"><text wx:if="{{card.rarity}}" class="badge badge-{{card.rarity}}">{{card.rarity}}</text></view></view>
    <view class="info-cell"><view class="lbl">品相</view><view class="val">{{condLabel}}</view></view>
    <view class="info-cell"><view class="lbl">数量</view><view class="val">{{card.quantity}}</view></view>
    <view class="info-cell"><view class="lbl">收购单价</view><view class="val">{{costPrice}}</view></view>
    <view class="info-cell"><view class="lbl">市场价</view><view class="val" style="color:var(--gold);">{{marketPrice}}</view></view>
    <view class="info-cell"><view class="lbl">持有总价</view><view class="val" style="color:var(--red);">{{totalValue}}</view></view>
    <view wx:if="{{card.notes}}" class="info-cell"><view class="lbl">备注</view><view class="val">{{card.notes}}</view></view>
  </view>

  <!-- Valuation -->
  <view class="valuation" wx:if="{{estPrice}}">
    <view>
      <view class="vlbl">当前估价</view>
      <view class="vval" style="color:var(--green);">{{estPrice}}</view>
    </view>
    <view>
      <view class="vlbl">总估值</view>
      <view class="vval" style="color:var(--gold);">{{estTotal}}</view>
    </view>
  </view>

  <!-- Actions -->
  <view style="display:flex;gap:16rpx;">
    <button class="btn btn-primary btn-sm" style="flex:1;" bindtap="showEditSheet">编辑</button>
    <button class="btn btn-outline btn-sm" style="flex:1;" bindtap="goPrice">查看价格</button>
    <button class="btn btn-danger btn-sm" bindtap="doDelete">删除</button>
  </view>

</view>

<view class="empty" wx:if="{{!card && !loading}}">
  <view class="msg">卡牌未找到</view>
  <button class="btn btn-outline btn-sm mt-md" bindtap="goBack">返回</button>
</view>

<!-- ====== Edit Sheet ====== -->
<view class="modal-mask" wx:if="{{showEdit}}" bindtap="hideEditSheet">
  <view class="modal-sheet" catchtap="noop">
    <view class="ms-header">
      <text class="title">编辑卡牌</text>
      <view class="close" bindtap="hideEditSheet">✕</view>
    </view>
    <view class="ms-body">
      <view class="img-upload" bindtap="pickEditImage">
        <image wx:if="{{edit.image}}" src="{{edit.image}}" mode="aspectFit"/>
        <view wx:else class="hint">点击更换图片</view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">卡名 *</view><input value="{{edit.name}}" data-k="name" bindinput="onEditField"/></view>
        <view class="form-field"><view class="label">英文名</view><input value="{{edit.name_en}}" data-k="name_en" bindinput="onEditField"/></view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">系列</view><input value="{{edit.set_name}}" data-k="set_name" bindinput="onEditField"/></view>
        <view class="form-field"><view class="label">编号</view><input value="{{edit.card_number}}" data-k="card_number" bindinput="onEditField"/></view>
      </view>
      <view class="form-row">
        <view class="form-field">
          <view class="label">稀有度</view>
          <picker range="{{rList}}" value="{{edit.rarityIdx}}" bindchange="onEditRarity">
            <view>{{rList[edit.rarityIdx]}}</view>
          </picker>
        </view>
        <view class="form-field">
          <view class="label">品相</view>
          <picker range="{{cList}}" value="{{edit.condIdx}}" bindchange="onEditCond">
            <view>{{cList[edit.condIdx]}}</view>
          </picker>
        </view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">数量</view><input type="number" value="{{edit.quantity}}" data-k="quantity" bindinput="onEditField"/></view>
        <view class="form-field"><view class="label">收购价 ¥</view><input type="digit" value="{{edit.cost_price}}" data-k="cost_price" bindinput="onEditField"/></view>
      </view>
      <view class="form-row">
        <view class="form-field"><view class="label">市场价 ¥</view><input type="digit" value="{{edit.market_price}}" data-k="market_price" bindinput="onEditField"/></view>
        <view class="form-field"><view class="label">备注</view><input value="{{edit.notes}}" data-k="notes" bindinput="onEditField"/></view>
      </view>
    </view>
    <view class="ms-footer">
      <button class="btn btn-outline" style="flex:1;" bindtap="hideEditSheet">取消</button>
      <button class="btn btn-primary" style="flex:1;" bindtap="saveEdit" loading="{{saving}}">保存修改</button>
    </view>
  </view>
</view>
