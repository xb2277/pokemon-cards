<!-- 资产看板 -->
<view class="page-container">

  <!-- Stats -->
  <view class="stats-strip" wx:if="{{!loading}}">
    <view class="stat-item"><view class="num">{{data.total_cards}}</view><view class="lbl">卡牌种类</view></view>
    <view class="stat-item"><view class="num num-gold">{{data.total_cost}}</view><view class="lbl">总成本</view></view>
    <view class="stat-item"><view class="num num-green">{{data.total_value}}</view><view class="lbl">当前估值</view></view>
    <view class="stat-item"><view class="num" style="color:{{data.profit >= 0 ? 'var(--green)' : 'var(--red)'}}">{{data.profit_display}}</view><view class="lbl">盈亏</view></view>
  </view>

  <!-- Charts -->
  <view style="display:flex;gap:16rpx;flex-wrap:wrap;">
    <view class="chart-card" style="flex:2;min-width:400rpx;">
      <h3>价值走势</h3>
      <ec-canvas wx:if="{{trendReady}}" id="trendChart" canvas-id="trendChart" ec="{{trendEc}}"></ec-canvas>
      <view wx:else style="text-align:center;padding:60rpx;color:var(--text3);">加载中...</view>
    </view>
    <view class="chart-card" style="flex:1;min-width:300rpx;">
      <h3>稀有度分布</h3>
      <ec-canvas wx:if="{{distReady}}" id="distChart" canvas-id="distChart" ec="{{distEc}}"></ec-canvas>
      <view wx:else style="text-align:center;padding:60rpx;color:var(--text3);">加载中...</view>
    </view>
  </view>

  <!-- Rankings -->
  <view style="display:flex;gap:16rpx;flex-wrap:wrap;margin-top:16rpx;">
    <view style="flex:1;min-width:320rpx;">
      <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;">
        <text style="font-weight:700;font-size:28rpx;">涨幅 TOP 10</text>
        <text style="font-size:20rpx;padding:4rpx 12rpx;border-radius:99rpx;background:rgba(5,150,105,.08);color:var(--green);">📈</text>
      </view>
      <view class="rank-list">
        <view class="rank-item" wx:for="{{gainers}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <text class="rank-num {{index < 3 ? 'hot' : ''}}">{{index + 1}}</text>
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-pct up">{{item.change_pct >= 0 ? '+' : ''}}{{item.change_pct}}%</text>
          <text class="rank-price">{{item.current_display}}</text>
        </view>
        <view wx:if="{{gainers.length === 0}}" style="padding:40rpx;text-align:center;color:var(--text3);">暂无数据</view>
      </view>
    </view>

    <view style="flex:1;min-width:320rpx;">
      <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;">
        <text style="font-weight:700;font-size:28rpx;">跌幅 TOP 10</text>
        <text style="font-size:20rpx;padding:4rpx 12rpx;border-radius:99rpx;background:rgba(239,68,68,.08);color:var(--red);">📉</text>
      </view>
      <view class="rank-list">
        <view class="rank-item" wx:for="{{losers}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <text class="rank-num {{index < 3 ? 'hot' : ''}}">{{index + 1}}</text>
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-pct down">{{item.change_pct >= 0 ? '+' : ''}}{{item.change_pct}}%</text>
          <text class="rank-price">{{item.current_display}}</text>
        </view>
        <view wx:if="{{losers.length === 0}}" style="padding:40rpx;text-align:center;color:var(--text3);">暂无数据</view>
      </view>
    </view>
  </view>

</view>
