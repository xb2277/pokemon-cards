<!-- 我的 -->
<view class="page-container">

  <!-- Header -->
  <view class="profile-header">
    <view class="avatar">🃏</view>
    <view class="title">宝可梦卡牌</view>
    <view class="sub">收藏 · 图鉴 · 行情</view>
  </view>

  <!-- Stats from API -->
  <view class="stats-strip" wx:if="{{stats.cards > 0}}">
    <view class="stat-item"><view class="num">{{stats.cards}}</view><view class="lbl">卡牌种类</view></view>
    <view class="stat-item"><view class="num num-gold">{{stats.qty}}</view><view class="lbl">总张数</view></view>
    <view class="stat-item"><view class="num">{{stats.cost}}</view><view class="lbl">总成本</view></view>
    <view class="stat-item"><view class="num" style="color:{{stats.profit >= 0 ? 'var(--green)' : 'var(--red)'}}">{{stats.profit}}</view><view class="lbl">盈亏</view></view>
  </view>

  <!-- Menu -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goDashboard">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-label">资产看板</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPrice">
      <view class="menu-left">
        <text class="menu-icon">📈</text>
        <text class="menu-label">价格行情</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCatalog">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-label">卡牌图鉴</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- Settings -->
  <view class="settings-section">
    <view class="ss-title">设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="showApiConfig">
        <view class="menu-left">
          <text class="menu-icon">🔗</text>
          <text class="menu-label">API 服务器地址</text>
        </view>
        <view style="display:flex;align-items:center;gap:8rpx;">
          <text style="font-size:22rpx;color:var(--text3);max-width:200rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{apiBase}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Version -->
  <view style="text-align:center;padding:48rpx;color:var(--text3);font-size:22rpx;">
    v1.0.0 · 数据来自自建服务器
  </view>

</view>

<!-- ====== API Config Sheet ====== -->
<view class="modal-mask" wx:if="{{showConfig}}" bindtap="hideConfig">
  <view class="modal-sheet" catchtap="noop">
    <view class="ms-header">
      <text class="title">API 服务器地址</text>
      <view class="close" bindtap="hideConfig">✕</view>
    </view>
    <view class="ms-body">
      <view class="form-field">
        <view class="label">服务器地址（HTTPS）</view>
        <input placeholder="https://your-server.com" value="{{apiUrlInput}}" bindinput="onApiInput"/>
      </view>
      <view style="font-size:22rpx;color:var(--text3);margin-top:8rpx;">
        请输入 Flask 后端部署后的完整 URL，不含末尾斜杠。
      </view>
    </view>
    <view class="ms-footer">
      <button class="btn btn-outline" style="flex:1;" bindtap="hideConfig">取消</button>
      <button class="btn btn-primary" style="flex:1;" bindtap="saveApiConfig">保存</button>
    </view>
  </view>
</view>
