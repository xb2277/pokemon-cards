/* index page — homepage + login styles */

/* Login sheet avatar button */
.login-avatar-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin: 0 auto;
  padding: 0;
  background: var(--card);
  border: 3rpx dashed var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: 1;
}
.login-avatar-btn::after { border: none; }
.login-avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.login-avatar-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
